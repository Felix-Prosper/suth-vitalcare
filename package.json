    "@types/compression": "^1.8.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vueform/vueform": "^1.13.10",
    "apexcharts": "^5.10.3",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "compression": "^1.8.1",
    "tsx": "^4.21.0",
    "cropperjs": "^1.6.2",
    "cross-fetch": "^4.1.0",
    "datatables.net": "^2.3.7",
    "datatables.net-dt": "^2.3.7",
    "datatables.net-vue3": "^3.0.4",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "fabric": "^7.2.0",
    "jquery": "^4.0.0",
    "lucide-vue-next": "^0.577.0",
    "moment": "^2.30.1",
