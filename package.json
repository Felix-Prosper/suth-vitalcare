{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"SERVER,TUNNEL\" -c \"bgBlue,bgGreen\" \"npm run server\" \"npm run tunnel\"",
    "test:speed": "npm run build && concurrently -n \"PROD,TUNNEL\" -c \"bgRed,bgGreen\" \"cross-env NODE_ENV=production tsx server/index.ts --prod\" \"npm run tunnel\"",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "server": "tsx server/index.ts",
    "tunnel": "cloudflared tunnel --url http://localhost:5001",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "seed:event-random": "tsx scripts/test-random-event.ts"
  },
  "dependencies": {
    "@line/bot-sdk": "^10.6.0",
    "@line/liff": "^2.27.3",
